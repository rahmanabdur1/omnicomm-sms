# App
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=omnicomm
DB_PASSWORD=secret
DB_NAME=omnicomm_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=_refresh_secret_here

# SMS API (Primary)
SMS_API_PROVIDER=twilio
SMS_API_KEY=_sms_api_key
SMS_API_SECRET=_sms_api_secret
SMS_FROM_NUMBER=+1234567890

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Gammu (GSM Fallback)
GAMMU_ENABLED=false
GAMMU_PORT=/dev/ttyUSB0



# bKash
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=your_app_key
BKASH_APP_SECRET=your_app_secret
BKASH_USERNAME=your_username
BKASH_PASSWORD=your_password

# SSLCommerz
SSL_STORE_ID=your_store_id
SSL_STORE_PASS=your_store_pass

# App URLs
BACKEND_URL=http://localhost:3001
# FRONTEND_URL=http://localhost:3000
ASTERISK_HOST=localhost
ASTERISK_AMI_USER=admin
ASTERISK_AMI_SECRET=secret


# 32-byte hex key: run `openssl rand -hex 32`
ENCRYPTION_KEY=your_64_char_hex_string_here
RECORDINGS_DIR=/var/spool/asterisk/monitor
STORAGE_BASE_URL=https://your-s3-bucket.s3.amazonaws.com
OPENAI_API_KEY=sk-...
WHATSAPP_ACCESS_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_VERIFY_TOKEN=...